---
// Menu.astro

const menus = [
	{
		id: 1,
		name: "Dimsum Cake Ultah",
		desc: "Rayakan momen spesialmu dengan Dimsum Cake unik! Perpaduan berbagai macam dimsum premium yang disusun cantik, lengkap dengan hiasan dan saus spesial. Alternatif kue ulang tahun yang lezat dan berkesan.",
		price: "Mulai Rp 98.000",
		image: "/images/dimsum-ultah.jpg",
		badge: "Spesial"
	},
	{
		id: 2,
		name: "Dimsum Berbagai Varian",
		desc: "Beraneka macam dimsum premium dengan isian daging ayam, udang, dan jamur pilihan. Disajikan hangat lengkap dengan saus spesial.",
		price: "Mulai Rp 10.000/pack",
		image: "/images/dimsum-mentai.jpeg",
		badge: "Best Seller"
	},
	{
		id: 3,
		name: "Tahu Bakso Toping",
		desc: "Perpaduan tahu lembut dan bakso daging sapi asli. Dilengkapi dengan berbagai macam topping yang menggugah selera.",
		price: "Rp 12.000",
		image: "/images/tahu-bakso.jpeg"
	},
	{
		id: 4,
		name: "Baso Bakar",
		desc: "Baso sapi kenyal dibakar dengan olesan bumbu pedas manis rahasia Mas Azis. Sensasi smoky yang nagih!",
		price: "Rp 2.000/pcs",
		image: "/images/bakso-bakar.jpeg"
	},
	{
		id: 5,
		name: "Roti Kukus Thailand",
		desc: "Roti kukus super lembut ala Thailand dengan isian srikaya, cokelat lumer, dan pandan wangi.",
		price: "Rp 6.000",
		image: "/images/roti-thailand.jpeg"
	},
	{
		id: 6,
		name: "Tahu Walik",
		desc: "Tahu pong yang diisi adonan bakso renyah di luar, empuk di dalam. Nikmat disantap dengan saus petis.",
		price: "Rp 2.000/pcs",
		image: "/images/tahu-walik.webp",
		badge: "Rekomendasi"
	},
	{
		id: 7,
		name: "Ekado",
		desc: "Nikmati perpaduan sempurna adonan daging pilihan yang gurih dengan kejutan telur puyuh utuh di dalamnya. Dibungkus dengan kulit tahu berkualitas yang menghasilkan sensasi krispi di setiap gigitan. Cocok untuk lauk praktis maupun camilan keluarga.",
		price: "Rp 10.000/3pcs",
		image: "/images/ekado.jpeg",
	}
];
---

<section id="menu" class="menu">
	<div class="container"> 
		<div class="text-center">
			<h2 class="section-title">Menu Andalan Kami</h2>
			<p class="section-subtitle">
				Pilihan jajanan berkualitas yang diracik khusus untuk memberikan rasa tak terlupakan di setiap gigitan.
			</p>
		</div>

		<div class="menu-grid">
			{menus.map((menu) => (
				<div class="menu-card">
					<div class="menu-image-container">
						<img src={menu.image} alt={menu.name} loading="lazy" class="menu-img" />
						{menu.badge && <span class="badge">{menu.badge}</span>}
					</div>
					<div class="menu-content">
						<div class="menu-header">
							<h3 class="menu-title">{menu.name}</h3>
							<span class="menu-price">{menu.price}</span>
						</div>
						<p class="menu-desc">{menu.desc}</p>
						<button class="order-btn">
							<span class="icon">🛒</span> Pesan
						</button>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.menu {
		background-color: var(--bg-light);
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 30px;
		margin-top: 40px;
	}

	.menu-card {
		background: var(--white);
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 10px 30px rgba(112, 51, 16, 0.05);
		transition: var(--transition);
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.menu-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 15px 40px rgba(229, 91, 19, 0.15);
	}

	.menu-image-container {
		position: relative;
		width: 100%;
		height: 240px;
		overflow: hidden;
	}

	.menu-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.menu-card:hover .menu-img {
		transform: scale(1.1);
	}

	.badge {
		position: absolute;
		top: 15px;
		right: 15px;
		background: var(--primary);
		color: var(--white);
		padding: 6px 14px;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		box-shadow: 0 4px 10px rgba(229, 91, 19, 0.3);
		z-index: 2;
	}

	.menu-content {
		padding: 25px;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 12px;
		gap: 15px;
	}

	.menu-title {
		font-size: 1.25rem;
		line-height: 1.3;
	}

	.menu-price {
		color: var(--primary);
		font-weight: 800;
		font-size: 1.1rem;
		white-space: nowrap;
	}

	.menu-desc {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 25px;
		flex-grow: 1;
	}

	.order-btn {
		width: 100%;
		padding: 12px;
		border: 1px solid rgba(229, 91, 19, 0.2);
		background: transparent;
		color: var(--primary);
		border-radius: 10px;
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		transition: var(--transition);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-family: 'Outfit', sans-serif;
	}

	.order-btn:hover {
		background: var(--primary);
		color: var(--white);
		border-color: var(--primary);
	}
</style>
