---
// Hero.astro
---

<section id="hero" class="hero">
	<div class="hero-bg">
		<!-- A slightly abstract shape or glow in the background -->
		<div class="glow glow-1"></div>
		<div class="glow glow-2"></div>
	</div>

	<div class="container hero-container">
		<div class="hero-content">
			<div class="hero-badge animate-fade-in-up">🌟 by Mas Azis</div>
			<h1 class="hero-title animate-fade-in-up" style="animation-delay: 0.1s">
				<span class="text-secondary">Rasa</span> <span class="text-primary">Terakhir.</span>
			</h1>
			<p class="hero-subtitle animate-fade-in-up" style="animation-delay: 0.2s">
				"Satu Suapan Yang Mengakhiri Pencarianmu"
			</p>
			<p class="hero-desc animate-fade-in-up" style="animation-delay: 0.3s">
				Mencari <strong>toko dimsum enak Serang</strong> atau yang <strong>jual dimsum Cikande</strong>? <strong>Rasa Terakhir</strong> adalah destinasi kuliner premium di Banten yang menyajikan dimsum berkualitas tinggi dengan cita rasa otentik, siap memanjakan lidah Anda.
			</p>
			
			<div class="hero-cta animate-fade-in-up" style="animation-delay: 0.4s">
				<a href="#menu" class="btn btn-primary">Lihat Menu</a>
				<a href="#contact" class="btn btn-outline">Pesan Sekarang</a>
			</div>
			
			<div class="hero-stats animate-fade-in-up" style="animation-delay: 0.5s">
				<div class="stat-item">
					<span class="stat-num">50+</span>
					<span class="stat-label">Varian Rasa</span>
				</div>
				<div class="stat-item">
					<span class="stat-num">100%</span>
					<span class="stat-label">Halal & Higienis</span>
				</div>
				<div class="stat-item">
					<span class="stat-num">Fresh</span>
					<span class="stat-label">Dibuat Setiap Hari</span>
				</div>
			</div>
		</div>

		<div class="hero-image-wrapper animate-fade-in-up" style="animation-delay: 0.2s">
			<div class="hero-image-inner">
				<img src="/images/hero.png" alt="Dimsum Premium Rasa Terakhir" class="hero-image" />
				<div class="floating-card floating-card-1">
					<div class="card-icon">🥟</div>
					<div class="card-text">Best Seller</div>
				</div>
				<div class="floating-card floating-card-2">
					<div class="card-icon">⭐</div>
					<div class="card-text">4.9/5 Rating</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		overflow: hidden;
		padding: 120px 0 60px;
		background-color: var(--bg-light);
	}

	.hero-bg {
		position: absolute;
		top: 0; left: 0; width: 100%; height: 100%;
		z-index: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.glow {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		z-index: 0;
		opacity: 0.5;
	}

	.glow-1 {
		top: -10%; left: -10%;
		width: 50vw; height: 50vw;
		background: radial-gradient(circle, rgba(229, 91, 19, 0.2) 0%, rgba(255,249,242,0) 70%);
	}

	.glow-2 {
		bottom: -20%; right: -10%;
		width: 40vw; height: 40vw;
		background: radial-gradient(circle, rgba(249, 160, 63, 0.2) 0%, rgba(255,249,242,0) 70%);
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	.hero-badge {
		display: inline-block;
		padding: 8px 16px;
		background: rgba(229, 91, 19, 0.1);
		color: var(--primary);
		font-weight: 700;
		border-radius: 50px;
		font-size: 0.9rem;
		margin-bottom: 24px;
	}

	.hero-title {
		font-size: 4.5rem;
		line-height: 1.05;
		margin-bottom: 12px;
		letter-spacing: -2px;
	}

	.text-secondary { color: var(--secondary); }
	.text-primary { color: var(--primary); }

	.hero-subtitle {
		font-size: 1.8rem;
		font-family: serif;
		font-style: italic;
		color: var(--accent);
		margin-bottom: 24px;
		font-weight: 600;
	}

	.hero-desc {
		font-size: 1.15rem;
		color: var(--text-muted);
		line-height: 1.7;
		margin-bottom: 40px;
		max-width: 90%;
	}

	.hero-cta {
		display: flex;
		gap: 20px;
		margin-bottom: 50px;
	}

	.hero-stats {
		display: flex;
		gap: 40px;
		padding-top: 30px;
		border-top: 1px solid rgba(112, 51, 16, 0.1);
	}

	.stat-item {
		display: flex;
		flex-direction: column;
	}

	.stat-num {
		font-size: 2rem;
		font-weight: 800;
		color: var(--secondary);
		line-height: 1;
		margin-bottom: 5px;
	}

	.stat-label {
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 600;
	}

	/* Image section */
	.hero-image-wrapper {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.hero-image-inner {
		position: relative;
		width: 100%;
		max-width: 500px;
		aspect-ratio: 1;
	}

	.hero-image-inner::before {
		content: '';
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 100%; height: 100%;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
		opacity: 0.15;
		z-index: -1;
		animation: pulse 4s infinite alternate;
	}

	@keyframes pulse {
		0% { transform: translate(-50%, -50%) scale(1); }
		100% { transform: translate(-50%, -50%) scale(1.05); }
	}

	.hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 50%;
		box-shadow: 0 30px 60px rgba(112, 51, 16, 0.2);
		border: 15px solid rgba(255, 255, 255, 0.5);
		transition: transform 0.5s ease;
	}

	.hero-image:hover {
		transform: rotate(2deg) scale(1.02);
	}

	/* Floating Cards */
	.floating-card {
		position: absolute;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px);
		padding: 12px 20px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		gap: 12px;
		box-shadow: 0 10px 30px rgba(112, 51, 16, 0.15);
		animation: float 5s infinite ease-in-out;
	}

	.floating-card-1 {
		top: 15%;
		left: -20px;
		animation-delay: 0s;
	}

	.floating-card-2 {
		bottom: 15%;
		right: -20px;
		animation-delay: 2.5s;
	}

	@keyframes float {
		0% { transform: translateY(0px); }
		50% { transform: translateY(-15px); }
		100% { transform: translateY(0px); }
	}

	.card-icon {
		font-size: 1.5rem;
		background: rgba(229, 91, 19, 0.1);
		width: 40px; height: 40px;
		display: flex; align-items: center; justify-content: center;
		border-radius: 50%;
	}

	.card-text {
		font-weight: 700;
		color: var(--secondary);
	}

	@media (max-width: 992px) {
		.hero-title { font-size: 3.5rem; }
		.hero-subtitle { font-size: 1.5rem; }
		.hero-container { grid-template-columns: 1fr; text-align: center; gap: 40px; }
		.hero-desc { margin: 0 auto 30px; }
		.hero-cta { justify-content: center; }
		.hero-stats { justify-content: center; }
		.hero-badge { margin: 0 auto 24px; }
		.section-title::after { left: 50%; transform: translateX(-50%); }
	}

	@media (max-width: 576px) {
		.hero-title { font-size: 2.8rem; }
		.hero-cta { flex-direction: column; }
		.hero-stats { flex-wrap: wrap; gap: 20px; }
		.floating-card { display: none; }
	}
</style>
